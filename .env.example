# Copy this file to .env and fill in real values

# LLM provider: "gemini" (default) or "mock" (for local/CI use without an API key)
LLM_PROVIDER=gemini

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model name (default is fine)
GEMINI_MODEL=gemini-1.5-flash

# Path to the DuckDB database file
DB_PATH=data/processed/cpg.duckdb

# Path where trained model is saved/loaded
MODEL_PATH=models/revenue_model.pkl

# API host/port (used by docker-compose and Makefile)
API_HOST=0.0.0.0
API_PORT=8000
